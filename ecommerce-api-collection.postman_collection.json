    {
      "name": "Vytvoreni produktu",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Vygenerovani nahodneho cisla pro unikatni nazev\r",
              "const randomId = Math.floor(Math.random() * 10000);\r",
              "const randomTitle = \"DevOps Lab \" + randomId;\r",
              "\r",
              "// Vygenerovani nahodne ceny od 100 do 2000\r",
              "const randomPrice = Math.floor(Math.random() * 1900) + 100;\r",
              "\r",
              "// Ulozeni techto hodnot do promennych, aby je Postman mohl pouzit v pozadavku\r",
              "pm.variables.set(\"dynamicTitle\", randomTitle);\r",
              "pm.variables.set(\"dynamicPrice\", randomPrice);"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Overeni status kodu (FakeStore API vraci 200 - ok nebo 201 - created)\r",
              "pm.test(\"Status code je 200 nebo 201\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "});\r",
              "\r",
              "// 2. Overeni rychlosti odpovedi (pod 2000 ms)\r",
              "pm.test(\"Response time je pod 2000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// --- DOPLNUJICI CVICENI (5 BODU) ---\r",
              "// Nejprve si ulozim odpoved ze serveru\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// 3. Overeni JSON struktury a datovych typu\r",
              "pm.test(\"Datove typy: ID je cislo a Title je text\", function () {\r",
              "    pm.expect(jsonData.id).to.be.a('number');\r",
              "    pm.expect(jsonData.title).to.be.a('string');\r",
              "});\r",
              "\r",
              "// 4. Overeni Business logiky (cena nesmi byt zaporna nebo nulova)\r",
              "pm.test(\"Business logic: Cena je vetsi nez 0\", function () {\r",
              "    // Pro jistotu prevedeme na cislo, kdyby to API vracelo jako text\r",
              "    const price = parseFloat(jsonData.price);\r",
              "    pm.expect(price).to.be.above(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
